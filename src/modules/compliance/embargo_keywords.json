  "cert_equivalence_map": {
    "MA": {"standard": "China Coal Safety (Mei'an)", "intl_equivalent": ["IECEx", "ATEX"], "note": "MA cert holders can apply for IECEx/ATEX conversion via accredited CB scheme"},
    "CNEx": {"standard": "China National Explosion-proof", "intl_equivalent": ["IECEx", "ATEX"], "note": "CNEx aligns with IEC 60079 series"},
    "CE": {"standard": "EU Conformity", "intl_equivalent": ["SIRIM", "MCMC Type Approval", "NBTC Type Approval", "IMDA Registration"], "note": "CE marking widely accepted as basis for local type approval conversion"},
    "FCC": {"standard": "US Federal Communications Commission", "intl_equivalent": ["SIRIM", "MCMC Type Approval", "NBTC Type Approval", "IMDA Registration"], "note": "FCC certification accepted as equivalent basis in most ASEAN markets"},
    "IECEx": {"standard": "International Electrotechnical Commission Explosive Atmospheres", "intl_equivalent": ["ATEX", "DGMS Approval"], "note": "Gold standard for international mining/hazardous area equipment"},
    "ATEX": {"standard": "EU Explosive Atmospheres Directive 2014/34/EU", "intl_equivalent": ["IECEx", "DGMS Approval"], "note": "EU directive, mutually recognized with IECEx"}
  }
