# ═══════════════════════════════════════════════════
#  TradeStealth_Core 环境变量模板
#  复制为 .env 后填入真实值
# ═══════════════════════════════════════════════════

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
INTENT_MODEL=gpt-4o-mini
STRATEGY_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/tradestealth

# --- Tick / FX volatility (supply_chain tick_pricing) ---
# mock | http — http 失败时回退 mock
TS_FX_VOLATILITY_SOURCE=mock
TS_FX_API_URL=
TS_FX_API_TIMEOUT_SEC=5

# --- Security ---
MACHINE_SECRET_SALT=your-custom-salt-here
# AES-256-GCM：64 个十六进制字符（32 字节）。生产请使用强随机密钥，例如：
#   python -c "import secrets; print(secrets.token_hex(32))"
# 未配置时 pytest 会通过 conftest.py 注入测试用占位密钥（勿用于生产）。
AES_MASTER_KEY=

# --- RPA ---
HEADLESS=true
PROXY_SERVER=
SLOW_MO=50

# --- Ghost Miner (供应链底价采集) ---
# MINER_MODE=mock | live；live 下默认 LCSC 搜索 URL 会对 query 做 URL 编码；
# 若扩展传入 target_urls，仅允许公网 http/https（拒绝 file://、127.0.0.1、RFC1918 等）。
PROXY_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
MINER_MODE=mock
MINER_TIMEOUT_SEC=15
