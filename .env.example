# ═══════════════════════════════════════════════════
#  TradeStealth_Core 环境变量模板
#  复制为 .env 后填入真实值
# ═══════════════════════════════════════════════════

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
INTENT_MODEL=gpt-4o-mini
STRATEGY_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/tradestealth

# --- Security ---
MACHINE_SECRET_SALT=your-custom-salt-here
AES_MASTER_KEY=  # 运行 python -c "from core.security import AESCipher; print(AESCipher.generate_key())" 生成

# --- RPA ---
HEADLESS=true
PROXY_SERVER=
SLOW_MO=50
