# ═══════════════════════════════════════════════════
#  TradeStealth_Core — Backend Production Dockerfile
# ═══════════════════════════════════════════════════
FROM python:3.12-slim

ENV TZ=Asia/Shanghai \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# 使用清华镜像加速 pip 安装
COPY requirements.txt .
RUN pip install --no-cache-dir \
    -i https://pypi.tuna.tsinghua.edu.cn/simple \
    --trusted-host pypi.tuna.tsinghua.edu.cn \
    -r requirements.txt

# 安装 Playwright 浏览器（仅 Chromium）
RUN playwright install --with-deps chromium

# 复制应用代码
COPY main.py .
COPY conftest.py .
COPY src/ src/
COPY db/ db/
COPY logs/ logs/

EXPOSE 8900

CMD ["gunicorn", "main:app", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "--bind", "0.0.0.0:8900"]
